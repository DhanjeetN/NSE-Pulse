# Cloudflare D1 — required for local dev (REST API to remote database)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_API_TOKEN=

# Do NOT set CF_API_TOKEN to a placeholder like "your-..." — it blocks the real token above.

# Local dev behind corporate VPN/proxy only (not needed on Cloudflare production)
D1_TLS_INSECURE=0
NSE_TLS_INSECURE=0
